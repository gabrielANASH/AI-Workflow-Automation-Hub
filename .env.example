# ────────────────────────────────────────────────────────
# FlowMind AI — Environment Configuration
# ────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
# PostgreSQL connection string (required)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Examples:
#   Local:   postgresql://postgres:postgres@localhost:5432/flowmind
#   Neon:    postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/flowmind?sslmode=require
#   Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/flowmind

# ── Authentication ────────────────────────────────────────
# Secret key for signing JWT tokens (required)
# Generate a strong key: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-change-in-production

# ── AI Providers ──────────────────────────────────────────
# Google Gemini API key (required)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Logging ───────────────────────────────────────────────
# Logging verbosity level (optional, default: info)
# Options: debug | info | warn | error
LOG_LEVEL=info

# ── Rate Limiting ─────────────────────────────────────────
# Maximum requests per minute per IP (optional, default: 100)
RATE_LIMIT_MAX=100

# ── Application ───────────────────────────────────────────
# Public URL of the deployed application (optional)
# Used for redirects and external links
NEXT_PUBLIC_APP_URL=http://localhost:3000
